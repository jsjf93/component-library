{
  "name": "component-library",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:icons": "pnpm --filter @borderline/icons build",
    "build:ui": "pnpm --filter @borderline/ui build",
    "build:demo": "pnpm --filter demo build",
    "dev:demo": "pnpm --filter demo dev",
    "storybook": "pnpm --filter @borderline/ui storybook",
    "build-storybook": "pnpm --filter @borderline/ui build-storybook",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "pnpm --filter \"@borderline/*\" publish --no-git-checks"
  },
  "devDependencies": {
    "prettier": "^3.9.5",
    "typescript": "~6.0.2"
  }
}