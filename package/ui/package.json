{
  "name": "@borderline/ui",
  "version": "0.1.0",
  "description": "A React component library built with Tailwind CSS v4.",
  "keywords": ["react", "ui", "components", "component-library", "tailwindcss", "design-system", "borderline"],
  "license": "MIT",
  "author": "Joshua Foster <jsjf93@hotmail.co.uk>",
  "homepage": "https://github.com/jsjf93/component-library/tree/main/package/ui#readme",
  "bugs": "https://github.com/jsjf93/component-library/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsjf93/component-library.git",
    "directory": "package/ui"
  },
  "type": "module",
  "files": ["dist"],
  "sideEffects": ["*.css"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": {
      "style": "./dist/styles.css",
      "import": "./dist/styles.css",
      "default": "./dist/styles.css"
    },
    "./theme.css": {
      "style": "./dist/theme.css",
      "import": "./dist/theme.css",
      "default": "./dist/theme.css"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build && cp src/theme.css dist/theme.css && echo '' > dist/index.css.d.ts",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@borderline/icons": "workspace:*",
    "@eslint/js": "^9.39.4",
    "@storybook/addon-a11y": "^10.0.7",
    "@storybook/addon-docs": "^10.0.7",
    "@storybook/react-vite": "^10.0.7",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "storybook": "^10.0.7",
    "tailwindcss": "^4.1.14",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  }
}
