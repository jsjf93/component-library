{
  "name": "@borderline/icons",
  "version": "0.1.0",
  "description": "Hand-authored SVG icon components for React, used by @borderline/ui.",
  "keywords": [
    "react",
    "icons",
    "svg",
    "components",
    "borderline"
  ],
  "license": "MIT",
  "author": "Joshua Foster <jsjf93@hotmail.co.uk>",
  "homepage": "https://github.com/jsjf93/component-library/tree/main/package/icons#readme",
  "bugs": "https://github.com/jsjf93/component-library/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsjf93/component-library.git",
    "directory": "package/icons"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9"
  }
}
